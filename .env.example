# Server
APP_HOST=0.0.0.0
APP_PORT=8000

# Storage
SQLITE_PATH=data/memories.db
CHROMA_PATH=data/chroma
DOCUMENTS_PATH=data/documents

# Embedding
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# LLM Provider: "openai" (NVIDIA, Ollama, vLLM, OpenAI) ou "bedrock"
LLM_PROVIDER=openai
LLM_MODEL_ID=meta/llama-3.1-8b-instruct
LLM_ENDPOINT_URL=http://localhost:8000/v1
LLM_API_KEY=

# AWS Bedrock (apenas quando LLM_PROVIDER=bedrock)
AWS_REGION=us-east-1
AWS_PROFILE=default
